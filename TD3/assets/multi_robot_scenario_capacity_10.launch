<launch>
  <arg name="gui" default="false"/>
  <arg name="enable_rviz" default="false"/>

  <include file="$(find multi_robot_scenario)/launch/empty_world.launch">
    <arg name="gui" value="false"/>
  </include>

  <param name="robot_description_r1"
         command="$(find xacro)/xacro '$(find multi_robot_scenario)/xacro/p3dx/pioneer3dx.xacro' velodyne_name:=r1_velodyne velodyne_topic:=/r1/velodyne_points robot_namespace:=/r1 tf_prefix:=r1"/>
  <node name="urdf_spawner_r1"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf -model r1 -param robot_description_r1 -x -2.70 -y -1.80 -z 0.01 -R 0 -P 0 -Y 0.0"/>

  <param name="robot_description_r2"
         command="$(find xacro)/xacro '$(find multi_robot_scenario)/xacro/p3dx/pioneer3dx.xacro' velodyne_name:=r2_velodyne velodyne_topic:=/r2/velodyne_points robot_namespace:=/r2 tf_prefix:=r2"/>
  <node name="urdf_spawner_r2"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf -model r2 -param robot_description_r2 -x -0.90 -y -1.80 -z 0.01 -R 0 -P 0 -Y 0.0"/>

  <param name="robot_description_r3"
         command="$(find xacro)/xacro '$(find multi_robot_scenario)/xacro/p3dx/pioneer3dx.xacro' velodyne_name:=r3_velodyne velodyne_topic:=/r3/velodyne_points robot_namespace:=/r3 tf_prefix:=r3"/>
  <node name="urdf_spawner_r3"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf -model r3 -param robot_description_r3 -x 0.90 -y -1.80 -z 0.01 -R 0 -P 0 -Y 0.0"/>

  <param name="robot_description_r4"
         command="$(find xacro)/xacro '$(find multi_robot_scenario)/xacro/p3dx/pioneer3dx.xacro' velodyne_name:=r4_velodyne velodyne_topic:=/r4/velodyne_points robot_namespace:=/r4 tf_prefix:=r4"/>
  <node name="urdf_spawner_r4"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf -model r4 -param robot_description_r4 -x 2.70 -y -1.80 -z 0.01 -R 0 -P 0 -Y 0.0"/>

  <param name="robot_description_r5"
         command="$(find xacro)/xacro '$(find multi_robot_scenario)/xacro/p3dx/pioneer3dx.xacro' velodyne_name:=r5_velodyne velodyne_topic:=/r5/velodyne_points robot_namespace:=/r5 tf_prefix:=r5"/>
  <node name="urdf_spawner_r5"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf -model r5 -param robot_description_r5 -x -2.70 -y 0.00 -z 0.01 -R 0 -P 0 -Y 0.0"/>

  <param name="robot_description_r6"
         command="$(find xacro)/xacro '$(find multi_robot_scenario)/xacro/p3dx/pioneer3dx.xacro' velodyne_name:=r6_velodyne velodyne_topic:=/r6/velodyne_points robot_namespace:=/r6 tf_prefix:=r6"/>
  <node name="urdf_spawner_r6"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf -model r6 -param robot_description_r6 -x -0.90 -y 0.00 -z 0.01 -R 0 -P 0 -Y 0.0"/>

  <param name="robot_description_r7"
         command="$(find xacro)/xacro '$(find multi_robot_scenario)/xacro/p3dx/pioneer3dx.xacro' velodyne_name:=r7_velodyne velodyne_topic:=/r7/velodyne_points robot_namespace:=/r7 tf_prefix:=r7"/>
  <node name="urdf_spawner_r7"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf -model r7 -param robot_description_r7 -x 0.90 -y 0.00 -z 0.01 -R 0 -P 0 -Y 0.0"/>

  <param name="robot_description_r8"
         command="$(find xacro)/xacro '$(find multi_robot_scenario)/xacro/p3dx/pioneer3dx.xacro' velodyne_name:=r8_velodyne velodyne_topic:=/r8/velodyne_points robot_namespace:=/r8 tf_prefix:=r8"/>
  <node name="urdf_spawner_r8"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf -model r8 -param robot_description_r8 -x 2.70 -y 0.00 -z 0.01 -R 0 -P 0 -Y 0.0"/>

  <param name="robot_description_r9"
         command="$(find xacro)/xacro '$(find multi_robot_scenario)/xacro/p3dx/pioneer3dx.xacro' velodyne_name:=r9_velodyne velodyne_topic:=/r9/velodyne_points robot_namespace:=/r9 tf_prefix:=r9"/>
  <node name="urdf_spawner_r9"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf -model r9 -param robot_description_r9 -x -2.70 -y 1.80 -z 0.01 -R 0 -P 0 -Y 0.0"/>

  <param name="robot_description_r10"
         command="$(find xacro)/xacro '$(find multi_robot_scenario)/xacro/p3dx/pioneer3dx.xacro' velodyne_name:=r10_velodyne velodyne_topic:=/r10/velodyne_points robot_namespace:=/r10 tf_prefix:=r10"/>
  <node name="urdf_spawner_r10"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf -model r10 -param robot_description_r10 -x -0.90 -y 1.80 -z 0.01 -R 0 -P 0 -Y 0.0"/>

  <group if="$(arg enable_rviz)">
    <node pkg="rviz"
          type="rviz"
          name="rviz"
          args="-d $(find multi_robot_scenario)/launch/pioneer3dx.rviz"/>
  </group>
</launch>
